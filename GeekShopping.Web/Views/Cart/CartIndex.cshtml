@model GeekShopping.Web.Models.CartViewModel

@if (Model.CartHeader != null && Model.CartDetails.Count() > 0)
{
    <form method="post">
        <br />
        <input asp-for="CartHeader.UserId" hidden />
        <input asp-for="CartHeader.Id" hidden />

        <div>
            <div class="card border-bottom mt-4 container">
                <div class="card-header bg-dark text-ligth ml-0 row">
                    <div class="col-6">
                        <i class="fas fa-shopping-cart"></i> &nbsp;
                        Shopping Cart
                    </div>
                    <div class="col-6">
                        <a asp-action="Index" asp-controller="Home" class="btn btn-outline-warning btn-sm ">
                            Continue Shopping
                        </a>
                    </div>
                </div>

                <div class="card-body">
                </div>

                <div class="card-footer row">
                </div>

                <div>
                </div>
            </div>
        </div>

    </form>

}
else
{
    <div>
        <p>Your cart is empty!</p>
    </div>
}